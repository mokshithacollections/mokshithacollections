# Copy to .env (next to docker-compose.yml) to override any of the defaults.
# .env is gitignored. NEVER commit real secrets.

# --- Postgres ---
POSTGRES_DB=mokshitha_collections
POSTGRES_USER=mokshitha
POSTGRES_PASSWORD=mokshitha_dev_password
POSTGRES_HOST_PORT=5432

# --- App ---
SPRING_PROFILES_ACTIVE=dev
APP_HOST_PORT=8081

# Hibernate schema strategy. Use `update` in dev, `validate` in prod (with migrations).
JPA_DDL_AUTO=update

# Spring Security signing key for remember-me cookies. MUST be 32+ chars in prod.
REMEMBER_ME_KEY=dev-only-replace-in-prod-at-least-32-chars

# Default admin seeded on first startup. Set these BEFORE the first `docker compose up`
# so your real admin is created instead of the default one.
ADMIN_EMAIL=admin@mokshitha.local
ADMIN_PASSWORD=ChangeMe!2026

# JVM tunables, e.g. -Xmx512m -Xms256m
JAVA_OPTS=
